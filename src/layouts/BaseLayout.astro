---
// BaseLayout.astro - 全局布局 (修复版)
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>万物精选 · 纯粹好用 - WVIP.TOP</title>
  <meta name="description" content="整理国家级政务服务、免费知识学习、实用在线工具、灵感推荐与全球知识，全平台无需会员、无诱导下载，纯粹好用的个人书签导航。" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌐</text></svg>" />
  <meta name="theme-color" content="#0a0a18" media="(prefers-color-scheme: dark)" />
</head>
<body class="theme-cyber">
  <canvas id="particlesCanvas"></canvas>
  <div id="rippleContainer"></div>
  <button class="theme-toggle" id="themeToggle" title="切换配色">🌓</button>

  <!-- 邮箱弹窗 -->
  <div class="modal-overlay" id="emailModal">
    <div class="modal">
      <p>📬 发送投稿邮件</p>
      <p>是否同意打开邮箱应用？</p>
      <div class="format-tip">
        邮件标题请写：来自（你的网名或昵称）的推荐<br>
        内容写：网址、它是干嘛的，两三句话就行。
      </div>
      <p class="countdown" id="countdownText">5 秒后可确认</p>
      <div class="btn-group">
        <button id="confirmBtn" disabled>是</button>
        <button id="cancelBtn">否</button>
      </div>
    </div>
  </div>

  <main>
    <slot />
  </main>

  <style is:global>
    :root {
      --bg: #0a0a18;
      --bg2: #0f0f22;
      --card-bg: rgba(18, 18, 36, 0.55);
      --card-border: rgba(100, 160, 220, 0.2);
      --card-hover-border: rgba(120, 190, 255, 0.5);
      --card-hover-glow: rgba(80, 150, 220, 0.2);
      --text: #e8e8f0;
      --text-dim: #9999aa;
      --text-title: #ffffff;
      --accent: #5ba0e8;
      --accent2: #9b6dff;
      --tag-bg: rgba(90, 150, 220, 0.15);
      --tag-text: #8ab8e8;
      --nav-active: #6db3f0;
      --nav-inactive: #667788;
      --ripple: rgba(120, 180, 240, 0.5);
      --badge-bg: rgba(100, 160, 220, 0.2);
      --badge-text: #a0c8f0;
      --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.4);
      --shadow-hover: 0 16px 48px rgba(30, 80, 160, 0.25);
      --transition-speed: 0.35s;
    }

    body.theme-pink {
      --bg: #1a0f14;
      --bg2: #1f1418;
      --card-bg: rgba(30, 16, 20, 0.55);
      --card-border: rgba(220, 140, 160, 0.2);
      --card-hover-border: rgba(255, 160, 180, 0.5);
      --card-hover-glow: rgba(220, 120, 150, 0.2);
      --text: #f0e4e8;
      --text-dim: #aa9599;
      --text-title: #ffffff;
      --accent: #e898a8;
      --accent2: #f0b0c0;
      --tag-bg: rgba(220, 140, 160, 0.15);
      --tag-text: #e8b0b8;
      --nav-active: #f0a0b0;
      --nav-inactive: #886670;
      --ripple: rgba(240, 150, 180, 0.5);
      --badge-bg: rgba(220, 140, 160, 0.2);
      --badge-text: #f0c0c8;
      --shadow-hover: 0 16px 48px rgba(180, 60, 100, 0.25);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      background-image:
        radial-gradient(ellipse at 30% 20%, var(--bg2) 0%, transparent 60%),
        radial-gradient(ellipse at 70% 80%, rgba(20, 20, 50, 0.6) 0%, transparent 50%);
      font-family: 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', 'Helvetica Neue', sans-serif;
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
      -webkit-tap-highlight-color: transparent;
      transition: background var(--transition-speed), color var(--transition-speed);
      position: relative;
    }

    #particlesCanvas {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none; z-index: 0;
    }

    #rippleContainer {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none; z-index: 0;
    }
    .ripple-ring {
      position: absolute; border-radius: 50%; border: 1.5px solid var(--ripple);
      animation: rippleExpand 1.2s ease-out forwards; pointer-events: none;
    }
    @keyframes rippleExpand {
      0% { width: 20px; height: 20px; opacity: 0.8; transform: translate(-50%, -50%) scale(0); }
      100% { width: 300px; height: 300px; opacity: 0; transform: translate(-50%, -50%) scale(1); }
    }

    .theme-toggle {
      position: fixed; bottom: 28px; right: 28px; width: 44px; height: 44px;
      border-radius: 50%; background: var(--card-bg); backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px); border: 1px solid var(--card-border);
      cursor: pointer; z-index: 100; display: flex; align-items: center; justify-content: center;
      font-size: 20px; color: var(--accent); transition: all var(--transition-speed);
      box-shadow: var(--shadow-card); user-select: none;
    }
    .theme-toggle:hover { border-color: var(--card-hover-border); box-shadow: var(--shadow-hover); transform: scale(1.08); }
    .theme-toggle:active { transform: scale(0.94); }

    .container {
      position: relative; z-index: 1; max-width: 1200px; margin: 0 auto;
      padding: 30px 24px 40px;
    }

    .header { text-align: center; padding: 30px 0 20px; position: relative; z-index: 2; }
    .header .logo {
      font-size: clamp(32px, 6vw, 52px); font-weight: 300; letter-spacing: 0.06em;
      color: var(--text-title);
      background: linear-gradient(135deg, #ffffff 0%, var(--accent) 70%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; filter: drop-shadow(0 0 18px rgba(100, 170, 240, 0.4));
      transition: filter var(--transition-speed); display: inline-block;
    }
    .header .slogan {
      display: block; font-size: clamp(14px, 2.5vw, 18px); font-weight: 300;
      letter-spacing: 0.2em; color: var(--text-dim); margin-top: 8px;
      transition: color var(--transition-speed);
    }

    .search-wrapper {
      display: flex; justify-content: center; margin: 10px 0 25px;
      position: sticky; top: 10px; z-index: 50;
    }
    .search-box {
      width: 100%; max-width: 480px; padding: 14px 20px; border-radius: 28px;
      background: var(--card-bg); backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px); border: 1px solid var(--card-border);
      color: var(--text); font-size: 15px; outline: none;
      transition: all 0.3s; box-shadow: var(--shadow-card);
    }
    .search-box::placeholder { color: var(--text-dim); opacity: 0.7; }
    .search-box:focus { border-color: var(--card-hover-border); box-shadow: var(--shadow-hover); }

    .no-result {
      text-align: center; color: var(--text-dim); font-size: 14px; margin: 20px 0;
      display: none;
    }
    .no-result a { color: var(--accent); cursor: pointer; text-decoration: none; }
    .no-result a:hover { text-decoration: underline; }

    .section-wrapper { margin-bottom: 20px; }
    .section-header {
      display: flex; align-items: center; justify-content: center; gap: 12px;
      cursor: pointer; padding: 14px 20px; border-radius: 14px;
      background: var(--card-bg); backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px); border: 1px solid var(--card-border);
      transition: all 0.3s; user-select: none; position: relative; z-index: 10;
    }
    .section-header:hover { border-color: var(--card-hover-border); box-shadow: var(--shadow-hover); }
    .section-title {
      font-size: clamp(16px, 3vw, 20px); font-weight: 500; letter-spacing: 0.06em;
      color: var(--text-title); margin: 0;
    }
    .section-arrow {
      font-size: 14px; color: var(--accent); transition: transform 0.3s; display: inline-block;
    }
    .section-wrapper.open .section-arrow { transform: rotate(180deg); }
    .section-content {
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.35s cubic-bezier(0.33, 1, 0.68, 1);
      margin-top: 0;
    }
    /* 修复：初始打开的板块内容可见 */
    .section-wrapper.open .section-content {
      max-height: none;
      margin-top: 16px;
    }

    .cards-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
    }
    .card {
      display: block; text-decoration: none; color: inherit;
      background: var(--card-bg); backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px); border: 1px solid var(--card-border);
      border-radius: 14px; padding: 18px 16px; position: relative; overflow: hidden;
      cursor: pointer; transition: all var(--transition-speed);
      box-shadow: var(--shadow-card);
    }
    .card::before {
      content: ''; position: absolute; top: 50%; left: 50%; width: 0; height: 0;
      border-radius: 50%; background: var(--card-hover-glow);
      transform: translate(-50%, -50%); transition: width 0.5s ease, height 0.5s ease, opacity 0.5s ease;
      pointer-events: none; z-index: 0; opacity: 0;
    }
    .card:hover::before { width: 350px; height: 350px; opacity: 1; }
    .card:hover { border-color: var(--card-hover-border); box-shadow: var(--shadow-hover); transform: translateY(-4px); z-index: 2; }
    .card:active { transform: scale(0.97); transition: transform 0.15s; }
    .card>* { position: relative; z-index: 1; }

    .card-icon { font-size: 22px; margin-bottom: 6px; display: block; }
    .card-title { font-size: 15px; font-weight: 600; letter-spacing: 0.03em; color: var(--text-title); margin-bottom: 4px; }
    .card-desc { font-size: 12px; color: var(--text-dim); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .card-badge { display: inline-block; font-size: 10px; padding: 3px 8px; border-radius: 10px; background: var(--badge-bg); color: var(--badge-text); margin-top: 8px; letter-spacing: 0.04em; }

    /* 折叠状态下移除毛玻璃提升性能 */
    .section-wrapper:not(.open) .card { backdrop-filter: none; -webkit-backdrop-filter: none; }
    .section-wrapper.open .card { backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); }

    .contribute {
      margin-top: 40px; padding: 24px 20px; border-radius: 14px;
      background: var(--card-bg); backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px); border: 1px solid var(--card-border);
      text-align: center; box-shadow: var(--shadow-card);
    }
    .contribute h2 { font-size: 18px; font-weight: 500; color: var(--text-title); margin-bottom: 10px; }
    .contribute .email-line { display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
    .contribute .email-btn {
      font-size: 16px; color: var(--accent);
      background: rgba(255,255,255,0.05); padding: 6px 16px; border-radius: 18px;
      border: 1px solid var(--card-border); cursor: pointer; transition: all 0.3s;
      display: inline-flex; align-items: center; gap: 4px;
    }
    .contribute .email-btn:hover { background: rgba(255,255,255,0.1); border-color: var(--card-hover-border); }
    .contribute .note {
      font-size: 11px; color: var(--text-dim); opacity: 0.8;
      max-width: 480px; margin: 0 auto;
    }

    .modal-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6);
      backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
      z-index: 200; display: flex; align-items: center; justify-content: center;
      visibility: hidden; opacity: 0; transition: all 0.3s;
    }
    .modal-overlay.active { visibility: visible; opacity: 1; }
    .modal {
      background: var(--card-bg); backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px); border: 1px solid var(--card-border);
      border-radius: 18px; padding: 25px 20px; max-width: 360px; text-align: center;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }
    .modal p { font-size: 15px; color: var(--text); margin-bottom: 12px; }
    .modal .format-tip { font-size: 13px; color: var(--text-dim); line-height: 1.6; margin-bottom: 15px; }
    .modal .countdown { font-weight: 600; color: var(--accent); margin-bottom: 15px; }
    .modal .btn-group { display: flex; gap: 12px; justify-content: center; }
    .modal button {
      padding: 10px 22px; border-radius: 22px; border: 1px solid var(--card-border);
      background: rgba(255,255,255,0.06); color: var(--text); cursor: pointer;
      font-size: 14px; transition: all 0.3s;
    }
    .modal button:hover { background: rgba(255,255,255,0.12); }
    .modal button:disabled { opacity: 0.4; cursor: not-allowed; }

    .footer {
      text-align: center; padding: 20px 0 10px; font-size: 11px; color: var(--text-dim);
      letter-spacing: 0.08em; line-height: 1.8;
    }
    .footer .statement { font-size: 12px; color: var(--text-dim); opacity: 0.9; margin-bottom: 6px; }
    .footer a { color: var(--accent); text-decoration: none; }

    /* 键盘焦点样式 */
    a:focus-visible, button:focus-visible, .section-header:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    @media (max-width: 1100px) { .cards-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 768px) {
      .cards-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
      .theme-toggle { bottom: 20px; right: 16px; width: 40px; height: 40px; font-size: 18px; }
    }
    @media (max-width: 480px) {
      .cards-grid { grid-template-columns: 1fr; gap: 10px; }
      .card { padding: 15px 14px; border-radius: 12px; }
      .card-title { font-size: 14px; }
      .card-desc { font-size: 11px; }
      .contribute { padding: 18px 14px; }
    }
  </style>

  <script>
    (function() {
      // ============ 粒子动画 ============
      const canvas = document.getElementById('particlesCanvas');
      const ctx = canvas.getContext('2d');
      let particles = [];
      const particleCount = 55;
      let animationFrameId = null;
      let isPageVisible = true;

      function resizeCanvas() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }
      resizeCanvas();
      window.addEventListener('resize', resizeCanvas);

      class Particle {
        constructor() {
          this.reset();
          this.y = Math.random() * canvas.height;
        }
        reset() {
          this.x = Math.random() * canvas.width;
          this.y = canvas.height + Math.random() * 80;
          this.size = Math.random() * 1.8 + 0.4;
          this.speedY = -(Math.random() * 0.25 + 0.08);
          this.speedX = (Math.random() - 0.5) * 0.15;
          this.opacity = Math.random() * 0.55 + 0.15;
          this.flickerSpeed = Math.random() * 0.015 + 0.003;
          this.flickerOffset = Math.random() * Math.PI * 2;
        }
        update() {
          this.y += this.speedY;
          this.x += this.speedX;
          if (this.y < -20 || this.x < -20 || this.x > canvas.width + 20) {
            this.reset();
            this.y = canvas.height + 20;
          }
        }
        draw(ctx, time) {
          const flicker = Math.sin(time * this.flickerSpeed + this.flickerOffset) * 0.35 + 0.65;
          const alpha = this.opacity * flicker;
          const isPink = document.body.classList.contains('theme-pink');
          const r = isPink ? 220 : 150;
          const g = isPink ? 150 : 180;
          const b = isPink ? 180 : 230;
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${r},${g},${b},${alpha})`;
          ctx.fill();
          if (this.size > 1) {
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size * 2.5, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(${r},${g},${b},${alpha * 0.12})`;
            ctx.fill();
          }
        }
      }
      for (let i = 0; i < particleCount; i++) particles.push(new Particle());

      function animateParticles(time) {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach(p => { p.update(); p.draw(ctx, time); });
        animationFrameId = requestAnimationFrame(animateParticles);
      }

      // 页面可见性 API 节能
      document.addEventListener('visibilitychange', () => {
        isPageVisible = !document.hidden;
        if (isPageVisible) {
          if (!animationFrameId) animationFrameId = requestAnimationFrame(animateParticles);
        } else {
          if (animationFrameId) {
            cancelAnimationFrame(animationFrameId);
            animationFrameId = null;
          }
        }
      });
      // 初始启动
      animationFrameId = requestAnimationFrame(animateParticles);

      // ============ 涟漪效果 ============
      const rippleContainer = document.getElementById('rippleContainer');
      document.addEventListener('keydown', (e) => {
        // 排除输入框内按键
        if (document.activeElement && document.activeElement.tagName === 'INPUT') return;
        if (e.key.length === 1 || e.key === 'Enter' || e.key === ' ') {
          const ripple = document.createElement('div');
          ripple.className = 'ripple-ring';
          ripple.style.left = (Math.random() * 80 + 10) + '%';
          ripple.style.top = (Math.random() * 70 + 15) + '%';
          rippleContainer.appendChild(ripple);
          ripple.addEventListener('animationend', () => ripple.remove());
        }
      });

      // ============ 配色切换（持久化） ============
      const themeToggle = document.getElementById('themeToggle');
      const STORAGE_KEY = 'wvip-theme';
      const savedTheme = localStorage.getItem(STORAGE_KEY);
      if (savedTheme === 'pink') {
        document.body.classList.add('theme-pink');
      }

      themeToggle.addEventListener('click', () => {
        const isPink = document.body.classList.toggle('theme-pink');
        localStorage.setItem(STORAGE_KEY, isPink ? 'pink' : 'cyber');
      });

      // ============ 折叠面板（稳定版） ============
      window.toggleSection = function(sectionId) {
        const wrapper = document.getElementById(sectionId);
        if (!wrapper) return;
        const content = wrapper.querySelector('.section-content');
        if (!content) return;
        const isOpen = wrapper.classList.contains('open');

        // 清除上一次可能未结束的过渡
        content.style.transition = 'none';
        content.offsetHeight; // 强制回流
        content.style.transition = 'max-height 0.35s cubic-bezier(0.33, 1, 0.68, 1)';

        if (isOpen) {
          // 收起：先固定当前高度，再过渡到 0
          content.style.maxHeight = content.scrollHeight + 'px';
          requestAnimationFrame(() => {
            content.style.maxHeight = '0px';
            content.style.marginTop = '0px';
          });
          wrapper.classList.remove('open');
        } else {
          // 展开：从 0 过渡到实际高度
          wrapper.classList.add('open');
          content.style.maxHeight = '0px';
          content.style.marginTop = '16px';
          const targetHeight = content.scrollHeight;
          requestAnimationFrame(() => {
            content.style.maxHeight = targetHeight + 'px';
          });

          // 过渡结束后移除固定高度，以适应内容变化
          const onTransitionEnd = (e) => {
            if (e.target === content && e.propertyName === 'max-height') {
              content.style.maxHeight = 'none';
              content.removeEventListener('transitionend', onTransitionEnd);
            }
          };
          content.addEventListener('transitionend', onTransitionEnd);
        }
      };

      // 初始化：确保标记为 open 的板块内容可见
      document.querySelectorAll('.section-wrapper.open .section-content').forEach(content => {
        content.style.maxHeight = 'none';
      });

      // ============ 邮箱弹窗（ESC 和背景关闭） ============
      const modal = document.getElementById('emailModal');
      const confirmBtn = document.getElementById('confirmBtn');
      const cancelBtn = document.getElementById('cancelBtn');
      const countdownText = document.getElementById('countdownText');
      let countdownTimer = null;

      function closeModal() {
        modal.classList.remove('active');
        if (countdownTimer) {
          clearInterval(countdownTimer);
          countdownTimer = null;
        }
      }

      window.openEmailModal = function() {
        modal.classList.add('active');
        let seconds = 5;
        confirmBtn.disabled = true;
        countdownText.textContent = `${seconds} 秒后可确认`;
        if (countdownTimer) clearInterval(countdownTimer);
        countdownTimer = setInterval(() => {
          seconds--;
          if (seconds <= 0) {
            clearInterval(countdownTimer);
            countdownText.textContent = '现在可以点击确定了';
            confirmBtn.disabled = false;
          } else {
            countdownText.textContent = `${seconds} 秒后可确认`;
          }
        }, 1000);
      };

      cancelBtn.addEventListener('click', closeModal);
      // 点击背景关闭
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });
      // ESC 关闭
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('active')) {
          closeModal();
        }
      });

      confirmBtn.addEventListener('click', () => {
        if (confirmBtn.disabled) return;
        const email = 'admin@wvip.top';
        const subject = '来自（你的网名或昵称）的推荐';
        window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}`;
        closeModal();
      });

      // ============ 卡片触摸反馈 ============
      document.addEventListener('touchstart', (e) => {
        const card = e.target.closest('.card');
        if (card) card.style.transform = 'scale(0.96)';
      }, { passive: true });
      document.addEventListener('touchend', (e) => {
        const card = e.target.closest('.card');
        if (card) card.style.transform = '';
      }, { passive: true });
      document.addEventListener('touchcancel', (e) => {
        const card = e.target.closest('.card');
        if (card) card.style.transform = '';
      }, { passive: true });

      // ============ 搜索功能（保留面板状态） ============
      const searchInput = document.getElementById('searchInput');
      const noResult = document.getElementById('noResult');
      let previousOpenStates = new Map(); // 存储搜索前的面板状态

      if (searchInput) {
        searchInput.addEventListener('input', function() {
          const term = this.value.trim().toLowerCase();
          let hasVisible = false;

          if (term) {
            // 首次输入时保存当前所有面板的展开状态
            if (previousOpenStates.size === 0) {
              document.querySelectorAll('.section-wrapper').forEach(w => {
                previousOpenStates.set(w.id, w.classList.contains('open'));
              });
            }
            // 展开所有面板以便搜索
            document.querySelectorAll('.section-wrapper').forEach(w => {
              if (!w.classList.contains('open')) {
                window.toggleSection(w.id);
              }
            });
          } else {
            // 清空搜索时恢复之前的状态
            document.querySelectorAll('.section-wrapper').forEach(w => {
              const wasOpen = previousOpenStates.get(w.id);
              const isOpenNow = w.classList.contains('open');
              if (wasOpen && !isOpenNow) {
                window.toggleSection(w.id);
              } else if (!wasOpen && isOpenNow) {
                window.toggleSection(w.id);
              }
            });
            previousOpenStates.clear();
          }

          // 搜索过滤
          document.querySelectorAll('.card').forEach(card => {
            const keywords = (card.getAttribute('data-keywords') || '') + ' ' +
              (card.querySelector('.card-title')?.textContent || '') + ' ' +
              (card.querySelector('.card-desc')?.textContent || '');
            if (!term || keywords.toLowerCase().includes(term)) {
              card.style.display = '';
              hasVisible = true;
            } else {
              card.style.display = 'none';
            }
          });

          if (noResult) {
            noResult.style.display = (term && !hasVisible) ? 'block' : 'none';
          }
        });
      }

      // 无结果链接滚动
      document.querySelector('.no-result a')?.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById('contributeSection')?.scrollIntoView({ behavior: 'smooth' });
      });
    })();
  </script>
</body>
</html>